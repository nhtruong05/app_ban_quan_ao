<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <TextView
        android:id="@+id/tvMsg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:accessibilityLiveRegion="polite"
        android:autoLink="none"
        android:background="@drawable/bg_user_msg"
        android:breakStrategy="simple"
        android:lineSpacingExtra="2dp"
        android:maxWidth="280dp"
        android:padding="12dp"
        android:textColor="@color/text_on_accent"
        android:textIsSelectable="true"
        android:textSize="14sp"
        app:layout_constraintEnd_toStartOf="@id/ivAvatarUser"
        app:layout_constraintHorizontal_bias="1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="(preview) Nội dung tin nhắn người dùng" />

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="8dp"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        app:layout_constraintEnd_toEndOf="@id/tvMsg"
        app:layout_constraintTop_toBottomOf="@id/tvMsg"
        tools:text="10:30" />

    <ImageView
        android:id="@+id/ivAvatarUser"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:contentDescription="@string/user_icon"
        android:src="@drawable/ic_user"
        app:layout_constraintBottom_toBottomOf="@id/tvMsg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvMsg" />
</androidx.constraintlayout.widget.ConstraintLayout>
