<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="12dp"
    android:paddingTop="8dp"
    android:paddingEnd="12dp"
    android:paddingBottom="8dp">

    <ImageView
        android:id="@+id/ivBotAvatarRow"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:contentDescription="@string/bot_icon"
        android:src="@drawable/ic_bot"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/cardProductBubble" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardProductBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_bot_msg"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toEndOf="@id/ivBotAvatarRow"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/img"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:src="@android:color/darker_gray"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:maxWidth="200dp"
            android:text="Tên sản phẩm"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toEndOf="@id/img"
            app:layout_constraintTop_toTopOf="@id/img" />

        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="2dp"
            android:text="250.000 đ"
            android:textColor="@color/price"
            android:textSize="13sp"
            app:layout_constraintStart_toEndOf="@id/img"
            app:layout_constraintTop_toBottomOf="@id/tvName" />

        <TextView
            android:id="@+id/tvMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:maxWidth="220dp"
            android:text="Áo • Size M • Cotton • Nam"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/img"
            app:layout_constraintTop_toBottomOf="@id/tvPrice" />

        <Button
            android:id="@+id/btnDetail"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:backgroundTint="@color/app_surface_muted"
            android:minWidth="64dp"
            android:minHeight="48dp"
            android:paddingHorizontal="12dp"
            android:text="Chi tiết"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            app:layout_constraintStart_toEndOf="@id/img"
            app:layout_constraintTop_toBottomOf="@id/tvMeta" />

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/accent_primary"
            android:minWidth="64dp"
            android:minHeight="48dp"
            android:paddingHorizontal="12dp"
            android:text="Thêm vào giỏ"
            android:textAllCaps="false"
            android:textColor="@color/text_on_accent"
            android:textSize="13sp"
            app:layout_constraintStart_toEndOf="@id/btnDetail"
            app:layout_constraintTop_toTopOf="@id/btnDetail" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="2dp"
        android:text="10:30"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        app:layout_constraintStart_toEndOf="@id/ivBotAvatarRow"
        app:layout_constraintTop_toBottomOf="@id/cardProductBubble" />
</androidx.constraintlayout.widget.ConstraintLayout>
