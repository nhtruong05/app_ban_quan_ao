<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".UserFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/app_background">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- HEADER HIỆN ĐẠI -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">

            <!-- Avatar tròn -->
            <ImageView
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:background="@color/app_surface_muted"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:tint="@color/text_primary"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <TextView
                    android:text="Tài khoản 1994 closet"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="Đăng nhập để quản lý đơn hàng, thông tin cá nhân và ưu đãi."
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- LOGIN -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/sectionLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:cardUseCompatPadding="true"
            app:strokeWidth="1dp"
            app:strokeColor="@color/border_default">

            <LinearLayout
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Đăng nhập"
                    android:textStyle="bold"
                    android:textSize="19sp"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="4dp" />

                <TextView
                    android:text="Đăng nhập để tiếp tục mua sắm, theo dõi đơn hàng và lưu giỏ hàng."
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tài khoản"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/accent_link"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtTaikhoan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Mật khẩu"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/accent_link"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtMatkhau"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Đăng nhập"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_accent"
                    android:layout_marginTop="16dp"
                    app:cornerRadius="16dp"
                    app:backgroundTint="@color/accent_primary" />

                <TextView
                    android:id="@+id/tvGotoRegister"
                    android:text="Chưa có tài khoản? Đăng ký ngay"
                    android:textColor="@color/accent_link"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- REGISTER -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/sectionRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:cardUseCompatPadding="true"
            app:strokeWidth="1dp"
            app:strokeColor="@color/border_default">

            <LinearLayout
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Đăng ký"
                    android:textStyle="bold"
                    android:textSize="19sp"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="4dp" />

                <TextView
                    android:text="Tạo tài khoản mới để nhận ưu đãi độc quyền và thanh toán nhanh hơn."
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tài khoản"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/accent_link"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtRegTaikhoan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Mật khẩu"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/accent_link"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtRegMatkhau"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Họ tên"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/accent_link"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtRegHoten"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Email"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/accent_link"
                    app:startIconDrawable="@android:drawable/ic_dialog_email">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtRegEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Số điện thoại"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/accent_link"
                    app:startIconDrawable="@android:drawable/ic_menu_call">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtRegSdt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Địa chỉ"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/accent_link"
                    app:startIconDrawable="@android:drawable/ic_dialog_map">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtRegDiachi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Đăng ký"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_accent"
                    android:layout_marginTop="16dp"
                    app:cornerRadius="16dp"
                    app:backgroundTint="@color/accent_link" />

                <TextView
                    android:id="@+id/tvGotoLogin"
                    android:text="Đã có tài khoản? Đăng nhập"
                    android:textColor="@color/accent_link"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- PROFILE -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/sectionProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp"
            app:cardUseCompatPadding="true"
            app:strokeWidth="1dp"
            app:strokeColor="@color/border_default">

            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Avatar + chào -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:background="@color/app_surface_muted"
                        android:padding="10dp"
                        android:tint="@color/text_primary" />

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1">

                        <TextView
                            android:id="@+id/tvWelcome"
                            android:text="Xin chào,"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:textColor="@color/text_primary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <TextView
                            android:text="Rất vui vì bạn đã đồng hành cùng VietNam Fashion."
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="16dp" />

                <!-- Thông tin tài khoản -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Tài khoản"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/tvTaikhoan"
                        android:textSize="16sp"
                        android:textColor="@color/text_body"
                        android:lineSpacingExtra="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:text="Họ tên"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/tvHoten"
                        android:textSize="16sp"
                        android:textColor="@color/text_body"
                        android:lineSpacingExtra="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:text="Email"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/tvEmail"
                        android:textSize="16sp"
                        android:textColor="@color/text_body"
                        android:lineSpacingExtra="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:text="Số điện thoại"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/tvSdt"
                        android:textSize="16sp"
                        android:textColor="@color/text_body"
                        android:lineSpacingExtra="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:text="Địa chỉ"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/tvDiachi"
                        android:textSize="16sp"
                        android:textColor="@color/text_body"
                        android:lineSpacingExtra="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Đăng xuất"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_accent"
                    android:layout_marginTop="20dp"
                    app:cornerRadius="16dp"
                    app:backgroundTint="@color/error" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
