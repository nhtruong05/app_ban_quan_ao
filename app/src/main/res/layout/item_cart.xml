<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardUseCompatPadding="true"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="96dp"
        android:padding="12dp">

        <!-- STT -->
        <TextView
            android:id="@+id/tvStt"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="1"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/imgThumb"
            app:layout_constraintBottom_toBottomOf="@id/imgThumb" />

        <!-- Ảnh sản phẩm -->
        <ImageView
            android:id="@+id/imgThumb"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:contentDescription="@string/app_name"
            android:background="@android:color/darker_gray"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/tvStt"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Tên -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tên sản phẩm"
            android:textStyle="bold"
            android:textSize="16sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintStart_toEndOf="@id/imgThumb"
            app:layout_constraintEnd_toStartOf="@id/btnDelete"
            app:layout_constraintTop_toTopOf="@id/imgThumb" />

        <!-- ID -->
        <TextView
            android:id="@+id/tvId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ID: 123"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="2dp"
            app:layout_constraintStart_toStartOf="@id/tvName"
            app:layout_constraintTop_toBottomOf="@id/tvName" />

        <!-- Size -->
        <TextView
            android:id="@+id/tvMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Size: M"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="2dp"
            app:layout_constraintStart_toStartOf="@id/tvName"
            app:layout_constraintTop_toBottomOf="@id/tvId" />

        <!-- Giá -->
        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="199.000 đ"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@id/tvName"
            app:layout_constraintBaseline_toBaselineOf="@id/tvMeta" />

        <!-- Nút giảm -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMinus"
            style="?attr/materialIconButtonFilledTonalStyle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="-"
            android:textStyle="bold"
            android:textSize="18sp"
            app:cornerRadius="10dp"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="@id/tvName"
            app:layout_constraintTop_toBottomOf="@id/tvMeta" />

        <!-- Số lượng -->
        <TextView
            android:id="@+id/tvQty"
            android:layout_width="56dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="1"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/btnMinus"
            app:layout_constraintTop_toTopOf="@id/btnMinus" />

        <!-- Nút tăng -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlus"
            style="?attr/materialIconButtonFilledTonalStyle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="+"
            android:textStyle="bold"
            android:textSize="18sp"
            app:cornerRadius="10dp"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/tvQty"
            app:layout_constraintTop_toTopOf="@id/btnMinus" />

        <!-- Nút xoá -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/btnDelete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_delete"
            android:contentDescription="@string/app_name"
            app:tint="?attr/colorError"
            app:shapeAppearanceOverlay="@style/Shape.Medium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
