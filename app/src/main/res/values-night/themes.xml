<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AppThoiTrang" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/text_on_accent</item>
        <item name="colorPrimaryContainer">@color/accent_soft</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>

        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorSecondaryContainer">@color/app_surface_muted</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>

        <item name="colorSurface">@color/app_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <item name="android:colorBackground">@color/app_background</item>
        <item name="colorSurfaceContainerLowest">@color/app_background</item>
        <item name="colorSurfaceContainerLow">@color/app_surface</item>
        <item name="colorSurfaceContainer">@color/app_surface_muted</item>
        <item name="colorSurfaceContainerHigh">@color/app_surface_elevated</item>

        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/app_surface_dark</item>
        <item name="colorOutline">@color/border_default</item>
        <item name="colorOutlineVariant">@color/divider_soft</item>

        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:navigationBarColor">@color/bottom_nav_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <item name="android:fontFamily">sans-serif</item>
        <item name="fontFamily">sans-serif</item>
    </style>
</resources>
